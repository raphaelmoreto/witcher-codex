<UserControl x:Class="WitcherCodex.WPF.Views.Bestiario.BestiarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WitcherCodex.WPF.Views.Bestiario"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Criaturas_Monstros}">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="300"
                            Margin="10"
                            Background="#2E2E2E"
                            CornerRadius="15"
                            ToolTipService.InitialShowDelay="200"
                            ToolTipService.ShowDuration="10000">

                        <!-- TOOLTIP -->
                        <Border.ToolTip>
                            <ToolTip Background="#1E1E1E" Padding="10">
                                <StackPanel>

                                    <TextBlock Text="Tipo"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   Margin="0 0 0 5"/>

                                    <TextBlock Text="{Binding Tipo}"
                                                   Foreground="White"
                                                   Margin="0 0 0 5"/>

                                    <TextBlock Text="Fraquezas"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   Margin="0 0 0 5"/>

                                    <ItemsControl ItemsSource="{Binding Fraquezas}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="White">
                                                        • <Run Text="{Binding Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>

                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <Image Source="{Binding Imagem}"
                                       Height="300"
                                       Stretch="UniformToFill"/>

                            <TextBlock Text="{Binding Nome}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding Descricao}"
                                           TextWrapping="Wrap"
                                           Foreground="LightGray"
                                           FontSize="12"
                                           Margin="5"
                                           TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
    </ScrollViewer>
</UserControl>
