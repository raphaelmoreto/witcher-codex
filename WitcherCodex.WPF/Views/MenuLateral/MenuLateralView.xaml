<UserControl x:Class="WitcherCodex.WPF.Views.MenuLateral.MenuLateralView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WitcherCodex.WPF.Views.MenuLateral"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True" 
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!--prism:ViewModelLocator.AutoWireViewModel="True": • ENCONTRA AUTOMATICAMENTE A "ViewModel" da View;
                                                                                       • CRIA O "ViewModel VIA INJEÇÃO DE DEPENDÊNCIA;
                                                                                       • DEFINE O "DataContext" SOZINHO"-->

    <UserControl.Resources>

        <!-- ESTILO BASE DO MENU -->
        <Style x:Key="MenuItemStyle" TargetType="RadioButton">

            <!-- APARÊNCIA BASE -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <!-- REMOVE BOLINHA PADRÃO -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">

                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="5,5"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3A3A3A"/>
                            </Trigger>

                            <!-- PRESSIONADO -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#505050"/>
                            </Trigger>

                            <!-- ITEM SELECIONADO -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#2D2D2D"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>

    <!-- LAYOUT -->
    <Border Background="#121212" Padding="10">
        <StackPanel>

            <Image Source="/Assets/Imagens/Logo/Logo.png"
                   Height="90"
                   Width="120" />


            <!-- TÍTULO -->
            <!--<TextBlock Text="Witcher Codex"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFE27A" Offset="0"/>
                        <GradientStop Color="#FFFFC300" Offset="0.3"/>
                        <GradientStop Color="#FFD4AF37" Offset="0.6"/>
                        <GradientStop Color="#FF8B7500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>-->

            <!-- MENU -->
            <RadioButton Content="Bestiário"
                         GroupName="Menu"
                         Style="{StaticResource MenuItemStyle}"
                         Command="{Binding MostrarBestiarioCommand}"
                         IsChecked="True" />

            <RadioButton Content="Óleos"
                         GroupName="Menu"
                         Style="{StaticResource MenuItemStyle}"
                         Command="{Binding MostrarOleosCommand}"/>

            <RadioButton Content="Poções"
                         GroupName="Menu"
                         Style="{StaticResource MenuItemStyle}"
                         Command="{Binding MostrarPocoesCommand}"/>

            <RadioButton Content="Sinais"
                         GroupName="Menu"
                         Style="{StaticResource MenuItemStyle}"
                         Command="{Binding MostrarSinaisCommand}"/>

        </StackPanel>
    </Border>
</UserControl>
