<Window x:Class="WitcherCodex.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WitcherCodex.WPF"
        xmlns:menu="clr-namespace:WitcherCodex.WPF.Views.MenuLateral"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        Background="#121212"
        Title="WitcherCodex" Height="600" Width="1000">
    
    <!--xmlns:prism="http://prismlibrary.com/": HABILITA O USO DO "Prism" NO XAML-->
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU -->
        <menu:MenuLateralView Grid.Column="0" />

        <!-- REGIÃO -->
        <ContentControl Grid.Column="1"
                    prism:RegionManager.RegionName="MainRegion" />
    </Grid>
</Window>
